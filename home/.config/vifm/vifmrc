colorscheme gruvbox

set vicmd=nvim
set syscalls
set notrash
set history=100
set nofollowlinks
set sortnumbers
set undolevels=100
set novimhelp
set norunexec
set timefmt=%Y-%m-%d\ %H:%M
set wildmenu
set wildstyle=popup
set ignorecase
set smartcase
set nohlsearch
set incsearch
set scrolloff=4
set statusline=" %t %= | %u:%g | %A | %8E | %d "

mark h ~/

filextype *.mp4,*.mkv,*.webm,*.avi,*.mov,*.flv,*.wmv mpv %c >/dev/null 2>&1 &
filextype *.mp3,*.flac,*.cue,*.ogg,*.opus,*.wav mpv %c >/dev/null 2>&1 &
filextype *.mid,*.midi fluidsynth -a pipewire ~/soundfonts/default.sf2 %c >/dev/null 2>&1 &
filextype *.jpg,*.jpeg,*.png,*.bmp,*.gif,*.tiff,*.tif swayimg %c >/dev/null 2>&1 &
filextype *.dng,*.rwl,*.nef,*.cr2,*.arw,*.orf swayimg %c >/dev/null 2>&1 &
filextype *.pdf zathura -- %c &
filextype *.md nvim %c
filextype *.tar,*.tar.gz,*.tgz,*.tar.bz2,*.tbz2,*.tar.xz,*.txz,*.zip,*.7z,*.rar :!bsdtar -tf %c | less
filextype *.html,*.htm firefox %c &
" don't just open random files
" filextype * xdg-open %c &

" toggle preview with the current file
nnoremap p :view<cr>
" open shell in current directory
nnoremap S :shell<cr>
" edit file
nnoremap e :edit<cr>
" rename file
nnoremap R :rename<cr>
" create directory
nnoremap md :mkdir<space>
" delete file
nnoremap dd :delete<cr>
" copy file
nnoremap yy :copy<cr>
" move file
nnoremap mv :move<cr>
" copy path of current file
nnoremap yp :!printf "%c:p" | wl-copy<cr>
" copy current directory path
nnoremap yd :!printf "%d" | wl-copy<cr>

set vifminfo=dhistory,savedirs,chistory,state,tui,shistory,phistory,fhistory,dirstack,registers,bookmarks,bmarks
" vim: filetype=vim
