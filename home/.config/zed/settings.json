{
  // theme and UI settings
  "cli_default_open_behavior": "existing_window",
  "diff_view_style": "unified",
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "context_servers": {
    "github": {
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": { "Authorization": "Bearer <token>" },
    },
    "datadog": {
      "enabled": true,
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
    },
  },
  "theme": "Gruvbox Dark",
  "ui_font_family": "Hack Nerd Font",
  "relative_line_numbers": "enabled",
  "ui_font_size": 17,
  "buffer_font_family": "Hack Nerd Font",
  "buffer_font_size": 17,
  "buffer_line_height": { "custom": 1.9 },
  "wrap_guides": [120],
  "outline_panel": { "dock": "right" },
  "project_panel": {
    "dock": "left",
    "folder_icons": false,
    "file_icons": false,
    "git_status": false,
    "show_diagnostics": "off",
    "hide_root": true,
    "hide_gitignore": true,
    "auto_fold_dirs": true,
    "indent_guides": { "show": "never" },
  },
  "git": {
    "gutter_debounce": 500,
    "inline_blame": {
      "enabled": false,
    },
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "git_status": false,
    "close_position": "left",
    "show_close_button": "always",
    "file_icons": false,
    "show_diagnostics": "off",
  },

  // editor settings
  "auto_update": false,
  "vim_mode": true,
  "autosave": "on_focus_change",
  "ensure_final_newline_on_save": true,
  "hard_tabs": false,
  "preferred_line_length": 120,
  "remove_trailing_whitespace_on_save": true,
  "soft_wrap": "none",
  "show_completions_on_input": false,

  // terminal settings
  "terminal": {
    "blinking": "terminal_controlled",
    "alternate_scroll": "off",
    "copy_on_select": true,
    "font_family": "Hack Nerd Font",
    "working_directory": "current_project_directory",
    "line_height": { "custom": 2 },
    "shell": { "program": "/opt/homebrew/bin/fish" },
    "toolbar": { "breadcrumbs": false },
  },

  // disable crap
  "minimap": { "show": "never" },
  "collaboration_panel": { "dock": "left", "button": false },
  "indent_guides": { "enabled": false },
  "debugger": { "button": false },
  // "search": { "button": false },
  "diagnostics": { "button": false },
  "telemetry": { "diagnostics": false, "metrics": false },
  "scrollbar": { "show": "never" },

  // files
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/node_modules",
    "**/log",
    "**/tmp",
    "**/.ruby-lsp",
    "**/.idea",
    "**/.vscode",
    "**/coverage",
    "**/.trivy",
  ],

  // AI
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^grep\\b"
            },
            {
              "pattern": "^head\\b"
            },
            {
              "pattern": "^sort\\b"
            },
            {
              "pattern": "^uniq\\b"
            },
            {
              "pattern": "^echo\\b"
            }
          ]
        }
      }
    },
    "sidebar_side": "right",
    "dock": "right",
    "use_modifier_to_send": true,
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": true
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": true,
        "effort": "high"
      }
    ],
    "enable_feedback": false,
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.8",
    },
    "thread_summary_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
  },
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true
    },
    "allow_data_collection": "no",
    "provider": "copilot",
    "mode": "eager",
    "disabled_globs": ["**/node_modules/**", "**/vendor/**", "**/tmp/**", "**/log/**"],
  },

  // LSP
  "lsp_highlight_debounce": 500,
  "lsp": {
    "ruby-lsp": {
      "settings": {
        "use_bundler": true,
      },
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
        },
      },
    },
    "rubocop": {
      "settings": {
        "use_bundler": true,
      },
      "initialization_options": {
        "safeAutocorrect": true,
      },
    },
  },

  // language-specific settings
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop", "!solargraph"],
      "tab_size": 2,
      "formatter": "language_server",
      "format_on_save": "off",
    },
  },

  // experimental features
  "experimental.theme_overrides": {
    // disable annoying highlights
    "editor.document_highlight.read_background": "#00000000",
    "editor.document_highlight.write_background": "#00000000",
  },
}
